{
	"compilerOptions": {
		"outDir": "dist",
		"rootDir": "src",
		"composite": true,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"target": "es2022",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true
	},
	"references": [
		{ "path": "../jarvis-shared" }
	],
	"include": ["src/**/*.ts"],
	"exclude": ["src/**/*.test.ts"]
}
