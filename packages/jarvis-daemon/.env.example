# =============================================================================
# Jarvis TS Daemon -- Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NOTE: .env is gitignored. Never commit credentials.
# =============================================================================

# -----------------------------------------------------------------------------
# Mailbox.org IMAP (email)
# MAILBOX_USER and MAILBOX_PASS are shared between IMAP, CalDAV, and CardDAV
# because mailbox.org uses a single set of credentials for all protocols.
# -----------------------------------------------------------------------------
MAILBOX_IMAP_HOST=imap.mailbox.org
MAILBOX_IMAP_PORT=993
MAILBOX_USER=
MAILBOX_PASS=

# -----------------------------------------------------------------------------
# Mailbox.org CalDAV (calendar and VTODO tasks)
# Uses MAILBOX_USER and MAILBOX_PASS above -- no additional credentials needed.
# -----------------------------------------------------------------------------
MAILBOX_CALDAV_URL=https://dav.mailbox.org

# -----------------------------------------------------------------------------
# YNAB Budget (personal finance)
# Get your access token at https://app.ynab.com/settings/developer
# Budget ID is the UUID in your YNAB URL: app.ynab.com/budgets/<uuid>/...
# -----------------------------------------------------------------------------
YNAB_ACCESS_TOKEN=
YNAB_BUDGET_ID=

# -----------------------------------------------------------------------------
# Telegram Bot
# Create a bot with @BotFather and get the token.
# JARVIS_TELEGRAM_CHAT_ID is your personal chat ID (use @userinfobot to find it).
# In shadow mode, use a SECOND bot token to avoid 409 Conflict with the Python service.
# -----------------------------------------------------------------------------
JARVIS_TELEGRAM_BOT_TOKEN=
JARVIS_TELEGRAM_CHAT_ID=

# -----------------------------------------------------------------------------
# Health endpoint
# TS daemon uses port 3334 to avoid conflicting with the Python jarvis on port 8085.
# -----------------------------------------------------------------------------
JARVIS_HEALTH_PORT=3334

# -----------------------------------------------------------------------------
# Neo4j Knowledge Graph (optional)
# Only required if using the jarvis-kg plugin or memory_consolidation heartbeat task.
# Neo4j is expected at bolt://localhost:7687 with user: neo4j
# -----------------------------------------------------------------------------
NEO4J_PASSWORD=
