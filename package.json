{
	"private": true,
	"workspaces": [
		"packages/jarvis-shared",
		"packages/jarvis-email",
		"packages/jarvis-daemon",
		"packages/jarvis-budget",
		"packages/jarvis-calendar",
		"packages/jarvis-files",
		"packages/jarvis-contacts",
		"packages/jarvis-kg"
	],
	"scripts": {
		"build": "tsc --build",
		"build:clean": "tsc --build --clean && tsc --build",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "biome check packages/",
		"lint:fix": "biome check --write packages/",
		"format": "biome format --write packages/"
	},
	"devDependencies": {
		"@biomejs/biome": "latest",
		"typescript": "^5.7.0",
		"vitest": "^4.1.2"
	}
}
